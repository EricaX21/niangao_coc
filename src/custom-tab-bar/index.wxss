.tab-bar {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  height: 56px;
  background-color: #e6e6e6;
  padding-bottom: env(safe-area-inset-bottom);
  position: relative;
  border-top: 1px solid #d9d9d9;
}

/* 左右两列 tab */
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding-top: 5px;
  box-sizing: border-box;
}

/* icon 圆形占位（MVP 阶段用色块代替真实 icon） */
.tab-icon-dot {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background-color: #999999;
}

.tab-icon-dot.active {
  background-color: #000000;
}

/* tab 文字 */
.tab-text {
  font-size: 10px;
  color: #999999;
  margin-top: 3px;
  line-height: 1.2;
}

.tab-text.active {
  color: #000000;
  font-weight: bold;
}
