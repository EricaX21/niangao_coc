<view class="tab-bar">
  <!-- 左列：发车（编辑器，即首页） -->
  <view
    class="tab-item"
    data-index="0"
    data-path="/pages/publish/index"
    bindtap="switchTab"
  >
    <view class="tab-icon-dot {{selected === 0 ? 'active' : ''}}"></view>
    <text class="tab-text {{selected === 0 ? 'active' : ''}}">发车</text>
  </view>

  <!-- 右列：我的 -->
  <view
    class="tab-item"
    data-index="1"
    data-path="/pages/mine/index"
    bindtap="switchTab"
  >
    <view class="tab-icon-dot {{selected === 1 ? 'active' : ''}}"></view>
    <text class="tab-text {{selected === 1 ? 'active' : ''}}">我的</text>
  </view>
</view>
